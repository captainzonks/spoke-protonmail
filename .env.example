# ==============================================================================
# PROTONMAIL MODULE - ENVIRONMENT VARIABLES
# ==============================================================================
# Description: Module-specific environment defaults for spoke-protonmail
# Author: Matt Barham
# Created: 2026-02-12
# Modified: 2026-04-21
# Version: 1.0.1
# Host: Your Server
# ==============================================================================
# Type: Template
# Security Level: MEDIUM - static IPs, ports, and GPG identity defaults
# Component: module: protonmail
# ==============================================================================
# Note: This file provides module defaults. Hub base.env variables are merged
#       automatically by Spoke. Site-specific overrides go in modules.yml.
# ==============================================================================

#### IMAGE (custom build from source)

PROTONMAIL_BRIDGE_GIT_VERSION=v3.22.0
PROTONMAIL_BRIDGE_TAG=1.0_${PROTONMAIL_BRIDGE_GIT_VERSION}-custom
PROTONMAIL_BRIDGE_IMAGE=spoke/protonmail-bridge:${PROTONMAIL_BRIDGE_TAG}

#### NETWORK

PROTONMAIL_IP=192.168.35.20
PROTONMAIL_HOST=mail.${DOMAIN}
PROTONMAIL_URI=https://mail.${DOMAIN}

#### PORTS (internal bridge ports, forwarded via socat)

PROTONMAIL_SMTP_PORT=1026
PROTONMAIL_IMAP_PORT=1144

#### GPG CONFIGURATION (for pass credential store)

GPG_NAME=proton-user
GPG_EMAIL=proton@fake.me
